# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=mp2
DB_SSL=false
DB_POOL_SIZE=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Object Storage (MinIO/S3)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=mp2-bucket
STORAGE_REGION=us-east-1

# Mailer (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM="MP2 vSM Platform <no-reply@example.com>"

# Viettel AI
AI_SPEECH_TO_TEXT_URL=https://api.viettelai.vn/speech2text
AI_SPEAKER_IDENTIFY_URL=https://api.viettelai.vn/speaker-identify
AI_API_KEY=change-me
AI_TIMEOUT_MS=10000

# Auth business constants
JWT_REFRESH_TTL_MS=604800000
OTP_TTL_MINUTES=10
OTP_COOLDOWN_SECONDS=60

# Transcription business constants
LIVE_RESUME_TTL_SECONDS=120
LIVE_MAX_CONCURRENT_SESSIONS=20
AI_MAX_CONCURRENCY=5
VAD_SILENCE_THRESHOLD_MS=600
